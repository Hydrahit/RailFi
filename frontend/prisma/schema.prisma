generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String               @id @default(cuid())
  email         String?              @unique
  name          String?
  image         String?
  walletAddress String?              @unique
  googleLinked  Boolean              @default(false)
  walletLinked  Boolean              @default(false)
  kycTier       Int                  @default(0)
  kycVerifiedAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  upiHandles    UpiHandle[]
  transactions  OfframpTransaction[]
  accounts      Account[]
  sessions      Session[]
}

model UpiHandle {
  id          String   @id @default(cuid())
  userId      String
  upiIdHashed String
  upiIdMasked String
  bankName    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OfframpTransaction {
  id             String   @id @default(cuid())
  transferId     String   @unique
  solanaTx       String   @unique
  cashfreeId     String   @unique
  walletAddress  String
  amountUsdc     Decimal
  amountInr      Decimal
  amountMicroUsdc String
  amountInrPaise Int
  upiMasked      String
  upiHash        String?
  status         String   @default("STAGED")
  utr            String?
  requiresReview Boolean  @default(false)
  failureReason  String?
  retryCount     Int      @default(0)
  lastRetryAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?
  referralPubkey String?
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  payoutAttempts PayoutAttempt[]
}

model DodoSettlementAudit {
  id                 String    @id @default(cuid())
  dodoPaymentId      String    @unique
  transferId         String?   @unique
  solanaTx           String?   @unique
  walletAddress      String
  customerEmail      String
  customerName       String?
  currency           String
  amountUsd          Decimal
  amountMicroUsdc    String
  inrQuotePaise      Int
  status             String
  failureReason      String?
  retryCount         Int       @default(0)
  lastRetryAt        DateTime?
  executionLockToken String?
  executionStartedAt DateTime?
  executedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model WebhookInbox {
  id             String    @id @default(cuid())
  provider       String
  sourcePath     String
  eventKey       String    @unique
  eventType      String
  payload        Json
  status         String    @default("RECEIVED")
  attemptCount   Int       @default(0)
  lastError      String?
  deadLetteredAt DateTime?
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  retryJobs      RetryJob[]
}

model RetryJob {
  id            String       @id @default(cuid())
  kind          String
  resourceType  String
  resourceId    String
  status        String       @default("QUEUED")
  attemptCount  Int          @default(0)
  maxAttempts   Int          @default(5)
  nextRunAt     DateTime     @default(now())
  lastAttemptAt DateTime?
  lastError     String?
  payload       Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  inboxId       String?
  inbox         WebhookInbox? @relation(fields: [inboxId], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@index([resourceType, resourceId])
}

model PayoutAttempt {
  id                 String               @id @default(cuid())
  transferId         String
  externalTransferId String               @unique
  kind               String
  rpcUrl             String?
  status             String               @default("QUEUED")
  errorReason        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  completedAt        DateTime?
  transaction        OfframpTransaction   @relation(fields: [transferId], references: [transferId], onDelete: Cascade)

  @@index([transferId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
